/* dark cockpit theme — mirrors luffa_superbox_fund.html palette */
page {
  background: #0E1116;
  color: #E8ECF2;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 26rpx;
  line-height: 1.5;
}

.page {
  min-height: 100vh;
  padding: 28rpx 28rpx 56rpx;
  box-sizing: border-box;
}

/* ---------- text ---------- */
.num   { font-family: ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace;
         font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
.muted { color: #9AA4B2; }
.dim   { color: #6B7480; }
.pos   { color: #4ADE80; }
.neg   { color: #F26D6D; }
.warn  { color: #E5A84B; }
.tk    { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; font-weight: 700; }

/* ---------- topbar ---------- */
.topbar {
  display: flex; align-items: center; gap: 14rpx;
  padding: 18rpx 8rpx 8rpx;
}
.topbar .brand   { font-size: 26rpx; font-weight: 600; letter-spacing: 0.02em; }
.topbar .sub     { color: #9AA4B2; font-size: 22rpx; margin-left: 4rpx; }
.topbar .health  { margin-left: auto; display: flex; align-items: center; gap: 10rpx;
                   font-family: ui-monospace, Menlo, monospace; font-size: 20rpx;
                   color: #9AA4B2; background: #1C232D;
                   border: 1rpx solid rgba(255,255,255,0.14);
                   padding: 6rpx 16rpx; border-radius: 8rpx; }
.topbar .health .dot { width: 12rpx; height: 12rpx; border-radius: 50%;
                        background: #E5A84B; box-shadow: 0 0 0 6rpx rgba(229,168,75,0.15); }
.topbar .health.live { color: #4ADE80; }
.topbar .health.live .dot { background: #4ADE80; box-shadow: 0 0 0 6rpx rgba(74,222,128,0.15); }

/* ---------- SFC compliance ribbon ---------- */
.sfc {
  display: flex; flex-direction: column; gap: 6rpx;
  background: rgba(45,212,191,0.05);
  border: 1rpx solid rgba(45,212,191,0.18);
  border-radius: 16rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 24rpx;
}
.sfc .sfc-h { display: flex; align-items: center; gap: 12rpx; font-size: 24rpx; color: #E8ECF2; }
.sfc .sfc-h .badge { background: linear-gradient(135deg,#2DD4BF,#4ADE80); color: #0E1116;
                     font-weight: 700; font-size: 20rpx; padding: 6rpx 12rpx; border-radius: 7rpx;
                     font-family: ui-monospace, Menlo, monospace; letter-spacing: 0.06em; }
.sfc .sfc-h b { color: #2DD4BF; font-weight: 600; }
.sfc .sfc-s { font-size: 22rpx; color: #9AA4B2;
              font-family: ui-monospace, Menlo, monospace; }

/* ---------- card ---------- */
.card {
  background: #161B22;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}
.card-h {
  display: flex; align-items: baseline; gap: 14rpx; margin-bottom: 16rpx;
}
.card-h .k { font-family: ui-monospace, Menlo, monospace; font-size: 20rpx;
             color: #2DD4BF; letter-spacing: 0.06em; }
.card-h .t { font-size: 28rpx; font-weight: 600; }
.card-h .n { margin-left: auto; font-size: 20rpx; color: #6B7480; }

/* ---------- buttons ---------- */
.btn {
  display: inline-block; text-align: center;
  font-size: 24rpx; font-weight: 600;
  padding: 16rpx 24rpx; border-radius: 12rpx;
  background: #2DD4BF; color: #0E1116; border: none;
}
.btn-ghost {
  background: transparent; color: #2DD4BF;
  border: 1rpx solid #2DD4BF;
}
.btn[disabled], .btn-ghost[disabled] { opacity: 0.4; }

/* ---------- demo data tag ---------- */
.demo-tag {
  font-family: ui-monospace, Menlo, monospace; font-size: 18rpx; color: #E5A84B;
  background: rgba(229,168,75,0.07);
  border: 1rpx solid rgba(229,168,75,0.4);
  padding: 4rpx 12rpx; border-radius: 7rpx;
}

/* ---------- divider ---------- */
.hr { height: 1rpx; background: rgba(255,255,255,0.08); margin: 18rpx 0; }
