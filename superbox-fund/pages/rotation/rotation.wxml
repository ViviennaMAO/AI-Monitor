<view class="page" wx:if="{{ready}}">

  <!-- HERO -->
  <view class="hero">
    <view class="topbar">
      <text class="brand">调仓引擎</text>
      <text class="sub">L3.5 · 三道闸</text>
      <view class="health {{status==='live' ? 'live' : ''}}">
        <view class="dot"></view>
        <text>{{status === 'live' ? 'LIVE' : 'DEMO'}}</text>
      </view>
    </view>
    <view class="hero-gates">
      <view class="hg"><text class="hg-n">1</text><text class="hg-l">触发</text></view>
      <view class="hg-arrow">→</view>
      <view class="hg"><text class="hg-n">2</text><text class="hg-l">候选</text></view>
      <view class="hg-arrow">→</view>
      <view class="hg"><text class="hg-n">3</text><text class="hg-l">验证</text></view>
    </view>
    <text class="hero-tip">换出有据 · 换入有名单 · 不自动执行</text>
  </view>

  <!-- BODY -->
  <view class="body">

    <!-- gate rules -->
    <view class="card">
      <view class="card-h">
        <text class="k">规则</text>
        <text class="t">三道闸校验</text>
      </view>
      <view class="rule">
        <view class="r-num">1</view>
        <view>
          <text class="r-g">触发</text>
          <text class="r-d">健康度 &lt; 70 · 触发器命中 · 段超配</text>
        </view>
      </view>
      <view class="rule">
        <view class="r-num">2</view>
        <view>
          <text class="r-g">候选</text>
          <text class="r-d">备用池就绪 ≥ 70 · 段位匹配 · 优选低 β</text>
        </view>
      </view>
      <view class="rule">
        <view class="r-num">3</view>
        <view>
          <text class="r-g">验证</text>
          <text class="r-d">单票 ≤ 18% · 前三大 ≤ 40% · Capex-β 不抬高</text>
        </view>
      </view>
    </view>

    <!-- auto suggestions -->
    <view class="card" wx:if="{{suggestions.length}}">
      <view class="card-h">
        <text class="k">自动建议</text>
        <text class="t">人工拍板</text>
      </view>
      <view class="sug" wx:for="{{suggestions}}" wx:key="text">
        <view class="sug-ic">{{item.icon}}</view>
        <view class="sg-body">
          <text class="tx">{{item.text}}</text>
          <text class="why">{{item.why}}</text>
        </view>
        <view class="sug-btn" data-out="{{item.out}}" data-in="{{item.in}}" bindtap="onLoadSuggestion">载入</view>
      </view>
    </view>

    <!-- simulator -->
    <view class="card">
      <view class="card-h">
        <text class="k">模拟器</text>
        <text class="t">不自动执行</text>
        <text class="n">先看影响</text>
      </view>

      <view class="simctl">
        <view class="sel-wrap">
          <text class="sw-lab">换出</text>
          <picker mode="selector" range-key="display" range="{{outOptions}}"
                  value="{{outIndex}}" bindchange="onSelOut">
            <view class="picker">{{outOptions[outIndex].display}}</view>
          </picker>
        </view>
        <view class="arrow-row">↓</view>
        <view class="sel-wrap">
          <text class="sw-lab">换入</text>
          <picker mode="selector" range-key="display" range="{{inOptions}}"
                  value="{{inIndex}}" bindchange="onSelIn">
            <view class="picker">{{inOptions[inIndex].display}}</view>
          </picker>
        </view>
      </view>
      <button class="btn" bindtap="onRunSim">模拟调仓</button>

      <view wx:if="{{simResult}}" class="simres">
        <!-- before / after table -->
        <view class="ba">
          <view class="c" wx:for="{{simResult.cells}}" wx:key="label">
            <text class="l">{{item.label}}</text>
            <view class="v">
              <text class="a">{{item.before}}{{item.unit}}</text>
              <text class="arr">→</text>
              <text class="{{item.tone}}" style="font-weight:700">{{item.after}}{{item.unit}}</text>
            </view>
          </view>
        </view>

        <!-- gates -->
        <view class="gates">
          <view class="gate {{simResult.gates.g1 ? 'ok' : 'na'}}">
            <text class="gh">闸 1 · 触发</text>
            <text>{{simResult.gates.g1Txt}}</text>
          </view>
          <view class="gate {{simResult.gates.g2 ? 'ok' : 'na'}}">
            <text class="gh">闸 2 · 候选</text>
            <text>{{simResult.gates.g2Txt}}</text>
          </view>
          <view class="gate {{simResult.gates.g3 ? 'ok' : 'no'}}">
            <text class="gh">闸 3 · 验证</text>
            <text>{{simResult.gates.g3Txt}}</text>
          </view>
        </view>

        <view class="verdict {{simResult.verdict.tone}}">
          <text>{{simResult.verdict.txt}}</text>
          <text wx:if="{{!simResult.gates.g3}}" class="neg"> · 闸3 未通过</text>
        </view>

        <view class="sandbox-note">
          <text class="hint">教学沙盒 · 仅展示三道闸如何评估调仓 · 不下单 / 不构成推荐</text>
        </view>
      </view>
    </view>

    <!-- bench -->
    <view class="card">
      <view class="card-h">
        <text class="k">备用池</text>
        <text class="t">候补 {{bench.length}} 只</text>
      </view>
      <view class="bench-list">
        <view class="bc" wx:for="{{bench}}" wx:key="ticker">
          <view class="bc-top">
            <view class="bc-tag" style="background: {{item.color}}"></view>
            <text class="tk">{{item.ticker}}</text>
            <text class="nm">{{item.name}}</text>
            <view class="cb-tag" style="background: {{item.cbBg}}; color: {{item.cbColor}}">β {{item.cbTxt}}</view>
          </view>
          <view class="ready">
            <view class="tr"><view style="width:{{item.readiness}}%; background:{{item.rcolor}}"></view></view>
            <text class="num readiness-num">就绪 {{item.readiness}}</text>
          </view>
          <text class="th">{{item.thesis}}</text>
          <text class="meta"><text class="meta-b">催化:</text>{{item.catalyst}}</text>
          <text class="trig">⤷ {{item.promotion_trigger}}</text>
        </view>
      </view>
    </view>

    <view class="foot">
      <text>数据截至 {{asOf}}</text>
      <text class="demo-tag" wx:if="{{status !== 'live'}}">演示数据</text>
    </view>
  </view>
</view>

<view class="page-loading" wx:else>
  <text class="muted">加载中…</text>
</view>
