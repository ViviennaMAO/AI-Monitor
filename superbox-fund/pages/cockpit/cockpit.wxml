<view class="page" wx:if="{{ready}}">

  <!-- ============ HERO (blue gradient) ============ -->
  <view class="hero">
    <view class="topbar">
      <text class="brand">LUFFA · BOX</text>
      <text class="sub">AI 生态基金</text>
      <view class="health {{status==='live' ? 'live' : ''}}" bindtap="onTapHealth">
        <view class="dot"></view>
        <text>{{status === 'live' ? 'LIVE' : 'DEMO'}}</text>
      </view>
    </view>

    <view class="sfc">
      <view class="sfc-h">
        <text class="badge">SFC</text>
        <text>Luffa 香港 · 证监会 1/4/9 号牌</text>
      </view>
      <text class="sfc-s">LAIF-I · 合格投资者 · 非投资建议</text>
    </view>

    <view class="hero-kpi">
      <text class="hk-lab">基金净值 / 累计</text>
      <text class="hk-val num">{{nav}}</text>
      <text class="hk-sub">{{status === 'live' ? '实时' : '演示数据'}} · 起始 1.000</text>
    </view>

    <view class="mini-row">
      <view class="mini">
        <view class="mi-ic mi-pos"><text>+</text></view>
        <view class="mi-body">
          <text class="mi-val num pos">+{{excessPct}}%</text>
          <text class="mi-lab">超额 vs 基准</text>
        </view>
      </view>
      <view class="mini">
        <view class="mi-ic mi-neg"><text>−</text></view>
        <view class="mi-body">
          <text class="mi-val num">−{{ddPct}}%</text>
          <text class="mi-lab">当前回撤</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ============ BODY ============ -->
  <view class="body">

    <!-- KPI mini bar -->
    <view class="card">
      <view class="kpi-grid">
        <view class="kp">
          <text class="kp-lab">组合 β</text>
          <text class="kp-val num">{{beta}}</text>
          <text class="kp-sub warn">偏进攻</text>
        </view>
        <view class="kp">
          <text class="kp-lab">现金仓位</text>
          <text class="kp-val num">{{cashPct}}%</text>
          <text class="kp-sub muted">已投 {{investedPct}}%</text>
        </view>
        <view class="kp">
          <text class="kp-lab">最大回撤</text>
          <text class="kp-val num">−{{mddPct}}%</text>
          <text class="kp-sub muted">滚动 1Y</text>
        </view>
      </view>
    </view>

    <!-- L1 · climate gate -->
    <view class="card">
      <view class="card-h">
        <text class="k">L1 · 气候层</text>
        <text class="t">市场气候门控</text>
        <text class="n">×{{regime.final_mult}}</text>
      </view>
      <view class="regime-top">
        <view class="season">{{regimeIcon}}</view>
        <view style="flex:1">
          <view class="verdict">{{regime.verdict.label}}</view>
          <view class="why">{{upCount}} 项偏多 / {{warnCount}} 项预警</view>
        </view>
      </view>
      <view class="gauge-wrap">
        <view class="gauge"></view>
        <view class="ptr" style="left: {{gaugePct}}%"></view>
        <view class="gauge-labs">
          <text>冬 · 防守</text><text>春秋 · 中性</text><text>夏 · 进攻</text>
        </view>
      </view>
      <view class="signals">
        <view class="sig" wx:for="{{regime.signals}}" wx:key="key">
          <text class="n">{{item.name}}{{item.is_master ? ' ★' : ''}}</text>
          <view class="v">
            <view class="dot" style="background: {{sigColor[item.state]}}"></view>
            <text>{{sigLabel[item.state]}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- L2 · exposure map -->
    <view class="card">
      <view class="card-h">
        <text class="k">L2 · 曝露层</text>
        <text class="t">价值链曝露</text>
        <text class="n">识别"假分散"</text>
      </view>
      <view class="expo-bar">
        <view class="seg compute" style="width: {{segPct.compute}}%">{{segPct.compute}}%</view>
        <view class="seg cloud"   style="width: {{segPct.cloud}}%">{{segPct.cloud}}%</view>
        <view class="seg app"     style="width: {{segPct.app}}%">{{segPct.app}}%</view>
        <view class="seg power"   style="width: {{segPct.power}}%">{{segPct.power}}%</view>
        <view class="seg cash"    style="width: {{segPct.cash}}%">{{segPct.cash}}%</view>
      </view>
      <view class="legend">
        <view class="lg"><view class="lg-d" style="background:#5468FF"></view><text>算力 · 4</text></view>
        <view class="lg"><view class="lg-d" style="background:#7C8CFF"></view><text>云 · 3</text></view>
        <view class="lg"><view class="lg-d" style="background:#A78BFA"></view><text>应用 · 2</text></view>
        <view class="lg"><view class="lg-d" style="background:#F59E0B"></view><text>供应链 · 1</text></view>
        <view class="lg"><view class="lg-d" style="background:#CBD5E1"></view><text>现金</text></view>
      </view>
      <view class="conc">
        <view class="b">
          <text class="v num">{{top1Pct}}%</text>
          <text class="l">第一大持仓</text>
        </view>
        <view class="b">
          <text class="v num">{{top3Pct}}%</text>
          <text class="l">前三大集中度</text>
        </view>
        <view class="b">
          <text class="v num warn">{{exposure.avg_correlation}}</text>
          <text class="l">平均相关</text>
        </view>
      </view>
      <view class="alert">
        <text class="a-i">⚠</text>
        <view>
          <text class="a-b">隐藏暴露:</text>10 标的中 {{exposure.capex_beta_high_count}} 个对 Capex 叙事高 β,真实独立判断 ≈ <text class="a-b">{{exposure.independent_bets_est}} 注</text>
        </view>
      </view>
    </view>

    <!-- PM identity -->
    <view class="card">
      <view class="card-h">
        <text class="k">PM · 身份</text>
        <text class="t">投资经理 Luffa 身份</text>
      </view>
      <block wx:if="{{wallet}}">
        <view class="wallet-on">
          <view class="wo-dot"></view>
          <view style="flex:1">
            <text class="wo-name">{{wallet.nickname || 'Luffa User'}}</text>
            <text class="wo-addr">{{wallet.address}}</text>
          </view>
        </view>
        <text class="hint">调仓单将以此身份签署</text>
      </block>
      <block wx:else>
        <button class="btn" bindtap="onConnect" disabled="{{connecting}}">
          {{connecting ? '连接中…' : '连接 Luffa 钱包'}}
        </button>
        <text class="hint">仅用 signMessageV2 签调仓单 · 不发起链上交易</text>
      </block>
      <view wx:if="{{connectError}}" class="err">{{connectError}}</view>
    </view>

    <view class="foot">
      <text>数据截至 {{asOf}}</text>
      <text class="demo-tag" wx:if="{{status !== 'live'}}">演示数据</text>
    </view>

  </view>
</view>

<view class="page-loading" wx:else>
  <text class="muted">加载中…</text>
</view>
