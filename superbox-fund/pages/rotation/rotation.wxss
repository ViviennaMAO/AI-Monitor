/* hero: three gate badges */
.hero-gates {
  display: flex; align-items: center; gap: 14rpx;
  margin-top: 24rpx; padding: 18rpx 20rpx;
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 20rpx;
}
.hero-gates .hg {
  flex: 1;
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.3);
  border-radius: 14rpx;
  padding: 10rpx 0;
  display: flex; flex-direction: column; align-items: center; gap: 4rpx;
}
.hero-gates .hg-n {
  font-family: ui-monospace, Menlo, monospace;
  font-size: 30rpx; font-weight: 800; color: #FFFFFF;
}
.hero-gates .hg-l {
  font-size: 20rpx; color: rgba(255,255,255,0.85);
}
.hero-gates .hg-arrow {
  color: rgba(255,255,255,0.6); font-size: 26rpx;
}
.hero-tip {
  display: block; margin-top: 14rpx;
  font-size: 20rpx; color: rgba(255,255,255,0.7);
  font-family: ui-monospace, Menlo, monospace;
}

/* gate rules */
.rule {
  display: flex; align-items: flex-start; gap: 16rpx;
  background: #F4F6FF;
  border-radius: 14rpx; padding: 16rpx 20rpx;
  margin-bottom: 12rpx;
}
.rule:last-child { margin-bottom: 0; }
.rule .r-num {
  width: 48rpx; height: 48rpx; border-radius: 14rpx;
  background: linear-gradient(135deg, #5468FF, #3D52E0);
  color: #FFFFFF; font-weight: 800; font-size: 24rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.rule .r-g  { display: block; font-family: ui-monospace, Menlo, monospace;
              font-size: 22rpx; color: #5468FF; font-weight: 700; }
.rule .r-d  { display: block; font-size: 22rpx; color: #1B1F3B; margin-top: 4rpx; line-height: 1.5; }

/* suggestions */
.sug {
  display: grid; grid-template-columns: auto 1fr auto;
  gap: 14rpx; align-items: center;
  background: linear-gradient(135deg, #F4F6FF, #EEF0FF);
  border-radius: 16rpx; padding: 18rpx;
  margin-bottom: 10rpx;
}
.sug .sug-ic {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  background: #FFFFFF; box-shadow: 0 4rpx 12rpx rgba(84,104,255,0.15);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #5468FF;
}
.sug .sg-body { display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.sug .tx  { font-size: 24rpx; color: #1B1F3B; line-height: 1.5; }
.sug .why { font-size: 20rpx; color: #6B7280;
            font-family: ui-monospace, Menlo, monospace; }
.sug-btn {
  font-family: ui-monospace, Menlo, monospace;
  font-size: 22rpx; color: #FFFFFF; background: #5468FF;
  padding: 10rpx 22rpx; border-radius: 10rpx; font-weight: 600;
  white-space: nowrap;
}

/* simulator controls */
.simctl {
  display: flex; flex-direction: column; gap: 14rpx;
  margin-bottom: 18rpx;
}
.sel-wrap { display: flex; flex-direction: column; gap: 6rpx; }
.sel-wrap .sw-lab { font-size: 22rpx; color: #6B7280; padding-left: 4rpx; }
.simctl .picker {
  background: #F4F6FF;
  border: 1rpx solid #E5E7EF;
  border-radius: 14rpx;
  padding: 18rpx 22rpx;
  font-family: ui-monospace, Menlo, monospace;
  font-size: 24rpx; color: #1B1F3B;
}
.simctl .arrow-row {
  text-align: center; font-size: 32rpx; color: #5468FF;
  font-weight: 800;
}

/* before / after */
.simres { border-top: 1rpx solid #E5E7EF; padding-top: 22rpx; margin-top: 22rpx; }
.ba {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 12rpx; margin-bottom: 18rpx;
}
.ba .c {
  background: #F4F6FF; border-radius: 12rpx; padding: 14rpx 8rpx; text-align: center;
  display: flex; flex-direction: column; gap: 6rpx;
}
.ba .c .l { font-size: 18rpx; color: #6B7280; }
.ba .c .v { font-family: ui-monospace, Menlo, monospace; font-size: 22rpx; color: #1B1F3B; }
.ba .c .v .a   { color: #9CA3AF; }
.ba .c .v .arr { color: #9CA3AF; margin: 0 4rpx; }

/* gates */
.gates { display: flex; flex-direction: column; gap: 10rpx; margin-bottom: 16rpx; }
.gate {
  border-radius: 14rpx; padding: 14rpx 18rpx; font-size: 22rpx; line-height: 1.5;
  border: 1rpx solid #E5E7EF;
}
.gate.ok { background: #ECFDF5; border-color: #A7F3D0; color: #047857; }
.gate.no { background: #FEF2F2; border-color: #FECACA; color: #991B1B; }
.gate.na { background: #F4F6FF; color: #6B7280; }
.gate .gh {
  display: block; font-family: ui-monospace, Menlo, monospace;
  font-size: 18rpx; opacity: 0.9; margin-bottom: 4rpx; font-weight: 700;
}

.verdict {
  padding: 16rpx 18rpx; border-radius: 14rpx;
  background: #F4F6FF;
  font-size: 24rpx; line-height: 1.5;
}
.verdict.pos   { color: #047857; background: #ECFDF5; }
.verdict.warn  { color: #B45309; background: #FFFBEB; }
.verdict.muted { color: #6B7280; }
.verdict .neg  { color: #DC2626; font-weight: 700; }

/* sign + ticket */
.sign-row {
  margin-top: 20rpx; display: flex; flex-direction: column; gap: 10rpx;
}
.hint { display: block; font-size: 20rpx; color: #9CA3AF; text-align: center; }
.ticket {
  margin-top: 14rpx; padding: 18rpx 20rpx;
  background: linear-gradient(135deg, #ECFDF5, #F0FDF4);
  border: 1rpx solid #A7F3D0;
  border-radius: 14rpx;
}
.ticket .t-head {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 10rpx;
}
.ticket .t-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; background: #10B981;
  box-shadow: 0 0 0 6rpx rgba(16,185,129,0.2);
}
.ticket .t-h { color: #047857; font-weight: 700; font-size: 24rpx; }
.ticket .mono {
  display: block; font-family: ui-monospace, Menlo, monospace;
  font-size: 18rpx; word-break: break-all; margin-bottom: 8rpx;
}
.err {
  margin-top: 12rpx; padding: 12rpx 16rpx;
  font-size: 22rpx; color: #991B1B;
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: 12rpx;
}

/* bench list */
.bench-list { display: flex; flex-direction: column; gap: 12rpx; }
.bc {
  background: #FFFFFF;
  border: 2rpx dashed #E5E7EF;
  border-radius: 16rpx; padding: 18rpx 22rpx;
}
.bc-top { display: flex; align-items: center; gap: 10rpx; }
.bc-tag {
  width: 8rpx; height: 28rpx; border-radius: 4rpx;
}
.bc .tk { font-family: ui-monospace, Menlo, monospace; font-weight: 800; font-size: 28rpx; color: #1B1F3B; }
.bc .nm { font-size: 22rpx; color: #6B7280; }
.bc .cb-tag {
  margin-left: auto;
  font-family: ui-monospace, Menlo, monospace;
  font-size: 18rpx; padding: 6rpx 14rpx; border-radius: 8rpx; font-weight: 700;
}
.ready { display: flex; align-items: center; gap: 14rpx; margin: 14rpx 0; }
.ready .tr { flex: 1; height: 10rpx; background: #F4F6FF; border-radius: 5rpx; overflow: hidden; }
.ready .tr view { display: block; height: 100%; border-radius: 5rpx; }
.readiness-num { font-size: 18rpx; color: #6B7280; }
.bc .th    { font-size: 22rpx; color: #1B1F3B; line-height: 1.5; display: block; }
.bc .meta  { font-size: 22rpx; color: #1B1F3B; display: block; margin-top: 8rpx; }
.bc .meta-b{ color: #5468FF; font-weight: 700; margin-right: 4rpx; }
.bc .trig  { font-size: 20rpx; color: #B45309; display: block; margin-top: 6rpx; line-height: 1.5; }

.foot {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 16rpx; padding: 0 8rpx;
  font-size: 22rpx; color: #9CA3AF;
}

.page-loading {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; color: #6B7280;
}
