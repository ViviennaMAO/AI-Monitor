/* KPI strip */
.kpis {
  display: flex; flex-wrap: wrap;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 14rpx; overflow: hidden;
  margin-bottom: 24rpx;
}
.kpi {
  flex: 1 0 33.333%;
  background: #161B22;
  padding: 18rpx 20rpx;
  display: flex; flex-direction: column; gap: 4rpx;
  border-right: 1rpx solid rgba(255,255,255,0.04);
  border-bottom: 1rpx solid rgba(255,255,255,0.04);
}
.kpi .lab { font-size: 20rpx; color: #9AA4B2; }
.kpi .val { font-size: 38rpx; font-weight: 600; }
.kpi .sub { font-size: 20rpx; margin-top: 2rpx; }

/* climate gauge */
.regime-top { display:flex; align-items:center; gap: 18rpx; margin-bottom: 18rpx; }
.season {
  width: 84rpx; height: 84rpx; border-radius: 20rpx;
  display:flex; align-items:center; justify-content:center;
  font-size: 42rpx; background: rgba(74,222,128,0.12);
  border: 1rpx solid rgba(74,222,128,0.3);
}
.regime-top .verdict { font-size: 30rpx; font-weight: 600; }
.regime-top .why     { font-size: 22rpx; color: #9AA4B2; margin-top: 4rpx; }

.gauge-wrap { position: relative; margin: 18rpx 4rpx 6rpx; }
.gauge {
  height: 14rpx; border-radius: 8rpx;
  background: linear-gradient(90deg, #3a4a6b 0%, #566072 32%, #9AA4B2 50%, #3fae8e 70%, #4ADE80 100%);
}
.ptr {
  position: absolute; top: -8rpx; width: 4rpx; height: 30rpx;
  background: #E8ECF2; border-radius: 3rpx;
  box-shadow: 0 0 0 6rpx rgba(232,236,242,0.15);
}
.gauge-labs {
  display: flex; justify-content: space-between;
  font-size: 18rpx; color: #6B7480; margin-top: 12rpx;
  font-family: ui-monospace, Menlo, monospace;
}

.signals {
  display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx;
  margin-top: 18rpx;
}
.sig {
  background: #1C232D;
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 10rpx;
  padding: 14rpx 16rpx;
  display: flex; flex-direction: column; gap: 4rpx;
}
.sig .n { font-size: 20rpx; color: #9AA4B2; }
.sig .v { display: flex; align-items: center; gap: 10rpx;
          font-family: ui-monospace, Menlo, monospace;
          font-size: 24rpx; font-weight: 600; }
.sig .v .dot { width: 12rpx; height: 12rpx; border-radius: 50%; }

/* exposure bar */
.expo-bar {
  display: flex; height: 56rpx; border-radius: 12rpx; overflow: hidden;
  margin-bottom: 16rpx;
}
.expo-bar .seg {
  display: flex; align-items: center; justify-content: center;
  font-family: ui-monospace, Menlo, monospace;
  font-size: 18rpx; font-weight: 600; color: #0E1116;
}
.expo-bar .compute { background: #8B7FE8; }
.expo-bar .cloud   { background: #2DD4BF; }
.expo-bar .app     { background: #F08A6B; }
.expo-bar .power   { background: #E5A84B; }
.expo-bar .cash    { background: #566072; color: #cdd5e2; }

.conc {
  display: grid; grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx; padding-top: 18rpx;
  border-top: 1rpx solid rgba(255,255,255,0.08);
}
.conc .b { text-align: center; display: flex; flex-direction: column; gap: 6rpx; }
.conc .b .v { font-size: 32rpx; font-weight: 600; }
.conc .b .l { font-size: 20rpx; color: #9AA4B2; }

.alert {
  display: flex; gap: 14rpx; margin-top: 18rpx;
  background: rgba(242,109,109,0.08);
  border: 1rpx solid rgba(242,109,109,0.28);
  border-radius: 10rpx; padding: 14rpx 16rpx;
}
.alert .a-i { color: #f3a3a3; font-size: 28rpx; }
.alert text { color: #f3a3a3; font-size: 22rpx; line-height: 1.5; }
.alert .a-b { color: #ffc0c0; font-weight: 600; }

/* wallet */
.wallet-row { font-size: 26rpx; margin-bottom: 8rpx; }
.hint { display: block; font-size: 20rpx; color: #6B7480; margin-top: 14rpx; }
.err {
  margin-top: 12rpx; padding: 10rpx 14rpx;
  font-size: 22rpx; color: #f3a3a3;
  background: rgba(242,109,109,0.07);
  border: 1rpx solid rgba(242,109,109,0.25);
  border-radius: 10rpx;
}

.foot {
  margin-top: 8rpx; font-size: 22rpx; color: #6B7480;
  display: flex; align-items: center; gap: 10rpx;
}
