/* hero stats (2 mini cards) */
.hero-stats { display: flex; gap: 14rpx; margin-top: 24rpx; }
.hs {
  flex: 1;
  background: rgba(255,255,255,0.18);
  border: 1rpx solid rgba(255,255,255,0.25);
  border-radius: 18rpx;
  padding: 16rpx 20rpx;
  display: flex; flex-direction: column; gap: 4rpx;
}
.hs .hs-lab { font-size: 20rpx; color: rgba(255,255,255,0.75); }
.hs .hs-val { font-size: 34rpx; font-weight: 700; color: #FFFFFF; }
.hs .hs-sub { font-size: 18rpx; color: rgba(255,255,255,0.6);
              font-family: ui-monospace, Menlo, monospace; }

/* segment chips inside hero */
.chips {
  margin-top: 24rpx; white-space: nowrap;
}
.chip {
  display: inline-block;
  font-family: ui-monospace, Menlo, monospace;
  font-size: 22rpx; color: rgba(255,255,255,0.85);
  background: rgba(255,255,255,0.15);
  border: 1rpx solid rgba(255,255,255,0.25);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  margin-right: 12rpx;
}
.chip.on { background: #FFFFFF; color: #5468FF; border-color: #FFFFFF; font-weight: 700; }

/* stock grid */
.grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx;
  margin-bottom: 20rpx;
}
.stk {
  position: relative;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 22rpx 22rpx 22rpx 26rpx;
  box-shadow: 0 6rpx 20rpx rgba(84,104,255,0.06);
  overflow: hidden;
}
.stk.sel  { box-shadow: 0 0 0 3rpx #5468FF, 0 6rpx 24rpx rgba(84,104,255,0.18); }
.stk.fire { box-shadow: 0 0 0 3rpx #EF4444, 0 6rpx 24rpx rgba(239,68,68,0.18); }
.stk.watch{ box-shadow: 0 0 0 2rpx #F59E0B, 0 6rpx 20rpx rgba(245,158,11,0.14); }
.stk .lcolor { position: absolute; left: 0; top: 0; bottom: 0; width: 8rpx; }
.stk .abadge { position: absolute; top: 14rpx; right: 14rpx;
               width: 14rpx; height: 14rpx; border-radius: 50%; }
.stk .row1   { display: flex; align-items: baseline; }
.stk .tk     { font-family: ui-monospace, Menlo, monospace; font-weight: 800; font-size: 30rpx;
               letter-spacing: 0.02em; flex: 1; color: #1B1F3B; }
.stk .wt     { font-size: 22rpx; color: #6B7280; }
.stk .chg    { font-size: 24rpx; margin-top: 8rpx; display: block; font-weight: 700; }
.stk .hbar   { height: 8rpx; border-radius: 5rpx; background: #F4F6FF;
               margin-top: 14rpx; overflow: hidden; }
.stk .hbar view { display: block; height: 100%; border-radius: 5rpx; }
.stk .h-num { display: block; font-size: 18rpx; color: #9CA3AF; margin-top: 4rpx; text-align: right; }

/* detail */
.detail.card {
  padding: 28rpx;
}
.detail .hd {
  display: flex; align-items: center; gap: 14rpx; flex-wrap: wrap;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid #E5E7EF; margin-bottom: 18rpx;
}
.detail .hd .tk   { font-family: ui-monospace, Menlo, monospace; font-weight: 800; font-size: 40rpx; color: #1B1F3B; }
.detail .hd .name { font-size: 22rpx; color: #6B7280; }
.detail .hd .pill { font-family: ui-monospace, Menlo, monospace; font-size: 18rpx;
                    padding: 6rpx 14rpx; border-radius: 8rpx; font-weight: 700; }
.detail .hd .wt   { margin-left: auto; text-align: right; }
.detail .hd .wt .b{ font-size: 32rpx; font-weight: 800; display: block; color: #1B1F3B; }
.detail .hd .wt .s{ font-size: 18rpx; display: block; }

.blk { margin-top: 20rpx; }
.blk .bh {
  display: block; font-family: ui-monospace, Menlo, monospace; font-size: 20rpx;
  color: #5468FF; letter-spacing: 0.06em; font-weight: 700; margin-bottom: 12rpx;
}
.pillars { display: flex; flex-direction: column; gap: 6rpx; }
.pl { display: flex; align-items: flex-start; gap: 12rpx; font-size: 24rpx; padding: 4rpx 0; color: #1B1F3B; }
.pl .pl-d { width: 12rpx; height: 12rpx; border-radius: 3rpx; background: #5468FF; margin-top: 12rpx; flex-shrink: 0; }

.kpiline {
  display: flex; justify-content: space-between;
  padding: 12rpx 0; border-bottom: 1rpx solid #F4F6FF;
  font-size: 24rpx;
}
.kpiline .v { font-weight: 700; color: #1B1F3B; }

.healthrow { display: flex; align-items: center; gap: 14rpx; }
.healthrow .track { flex: 1; height: 12rpx; background: #F4F6FF; border-radius: 6rpx; overflow: hidden; }
.healthrow .track view { display: block; height: 100%; border-radius: 6rpx; }
.healthrow .h-big { font-size: 30rpx; font-weight: 800; color: #1B1F3B; }
.h-note { display: block; font-size: 22rpx; margin-top: 8rpx; }

.trip {
  background: #FEF2F2;
  border: 1rpx solid #FECACA;
  border-radius: 12rpx; padding: 14rpx 16rpx;
  font-size: 22rpx; color: #991B1B;
}
.trip .b { color: #DC2626; font-weight: 700; margin-right: 6rpx; }
.monitor {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 12rpx; font-size: 22rpx; color: #1B1F3B;
}

/* circuit breakers */
.cbrow { display: grid; grid-template-columns: 1fr; gap: 12rpx; }
.cbx {
  background: #F4F6FF;
  border-radius: 12rpx; padding: 16rpx 20rpx;
}
.cbx .h  { display: block; font-size: 22rpx; color: #6B7280; }
.cbx .st { display: flex; align-items: center; gap: 10rpx; margin-top: 8rpx;
           font-family: ui-monospace, Menlo, monospace; font-size: 26rpx; font-weight: 700; color: #1B1F3B; }
.cbx .st .dot { width: 14rpx; height: 14rpx; border-radius: 50%; }
.cbx .lad { display: block; font-size: 20rpx; color: #9CA3AF; margin-top: 8rpx;
            font-family: ui-monospace, Menlo, monospace; }

/* alerts list */
.ai {
  display: grid; grid-template-columns: auto 1fr auto;
  gap: 14rpx; align-items: center;
  padding: 18rpx; border-radius: 14rpx;
  background: #FFFFFF; margin-bottom: 12rpx;
  border: 1rpx solid #E5E7EF;
}
.ai.fire  { border-color: #FECACA; background: #FEF2F2; }
.ai.watch { border-color: #FED7AA; background: #FFFBEB; }
.ai .sev  { font-family: ui-monospace, Menlo, monospace; font-size: 18rpx; font-weight: 800;
            padding: 6rpx 14rpx; border-radius: 8rpx; white-space: nowrap; align-self: start; }
.ai .sev.fire  { background: #EF4444; color: #FFFFFF; }
.ai .sev.watch { background: #F59E0B; color: #FFFFFF; }
.ai .cond-wrap { display: flex; flex-direction: column; gap: 4rpx; min-width: 0; }
.ai .cond-wrap .tk   { font-family: ui-monospace, Menlo, monospace; font-weight: 800; font-size: 28rpx; color: #1B1F3B; }
.ai .cond-wrap .cond { font-size: 22rpx; color: #1B1F3B; }
.ai .cond-wrap .sub  { font-size: 18rpx; }
.ai .val  { text-align: right; font-family: ui-monospace, Menlo, monospace; font-size: 24rpx; font-weight: 700; }
.ai .val .val-thr { display: block; font-size: 18rpx; font-weight: normal; }
.ai .push {
  grid-column: 1 / -1;
  font-family: ui-monospace, Menlo, monospace; font-size: 22rpx;
  color: #FFFFFF; background: linear-gradient(135deg, #5468FF, #3D52E0);
  border: none; padding: 14rpx 0; border-radius: 12rpx;
  margin-top: 8rpx;
}

.foot {
  display: flex; align-items: center; gap: 12rpx;
  margin-top: 16rpx; padding: 0 8rpx;
  font-size: 22rpx; color: #9CA3AF;
}

.page-loading {
  display: flex; align-items: center; justify-content: center;
  min-height: 100vh; color: #6B7280;
}
